{
  "manifest_version": 3,
  "name": "Google Maps Recorder",
  "version": "1.0",

  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.google.com/maps/*", "https://www.google.com.my/maps/*"],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*", "https://www.google.com.my/maps/*"],
      "js": ["dist/content2.js"],
      "run_at": "document_idle"
    }
  ]
}